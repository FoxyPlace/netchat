# Fichiers de configuration sensibles
config.php
.env
*.log

# Photos / médias uploadés (contenu utilisateur, pas le code)
public/assets/posts/*
!public/assets/posts/.gitkeep
public/assets/users_profile_pictures/*
!public/assets/users_profile_pictures/.gitkeep
assets/users_profile_pictures/*
!assets/users_profile_pictures/.gitkeep

# Fichiers temporaires
temp/
*.tmp

# Fichiers système
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Base de données (si fichiers SQL de backup)
*.sql.backup
*.sql.bak
